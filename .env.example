# Freelance MCP Server Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================================================
# REQUIRED: AI/LLM Configuration
# ============================================================================

# GROQ API Key (Required for AI-powered proposal generation)
# Get your free API key from: https://console.groq.com/
GROQ_API_KEY=gsk_your_groq_api_key_here

# OpenAI API Key (only if AUTO_BID_AI_PROVIDER=openai — paid)
OPENAI_API_KEY=sk_your_openai_api_key_here

# Google Gemini API Key (free tier — https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Mistral API Key (free tier — https://console.mistral.ai/)
MISTRAL_API_KEY=your_mistral_api_key_here

# Cerebras API Key (free tier — https://cloud.cerebras.ai/)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Proposal generation AI — pick one:
#   groq      (free) llama-3.3-70b-versatile
#   gemini    (free) gemini-3-flash-preview
#   mistral   (free) mistral-small-latest
#   cerebras  (free) llama-3.3-70b
#   ollama    (free, local) llama3.2
#   openai    (paid) gpt-5.3
AUTO_BID_AI_PROVIDER=groq
AUTO_BID_AI_MODEL=llama-3.3-70b-versatile
AUTO_BID_AI_TEMPERATURE=0.7

# ── Bid amount strategy (range-based) ────────────────────────────────────────
# Format: AUTO_BID_RANGE_<N>=budget_min_usd,budget_max_usd,bid_percentage
# Bid = budget_max * (pct / 100). Matched against the project's max budget.
#
#   $0–$250     → 80%   (small jobs, stay competitive)
#   $251–$1000  → 75%
#   $1001–$5000 → 70%
#   $5001+      → 65%   (large jobs, leave room to negotiate)
#
AUTO_BID_RANGE_1=0,250,80
AUTO_BID_RANGE_2=251,1000,75
AUTO_BID_RANGE_3=1001,5000,70
AUTO_BID_RANGE_4=5001,999999,65

# Fallback % of budget_max if no range matches (default 90%)
AUTO_BID_FALLBACK_PCT=90

# Default skills pre-filled in the search prompt (override from terminal if needed)
# DEFAULT_SEARCH_SKILLS=Mobile App Development, React Native, Flutter, OpenAI

# ============================================================================
# REQUIRED: Owner Validation
# ============================================================================

# Owner Phone Number (Required for validate tool)
# Country code without '+' sign
OWNER_COUNTRY_CODE=1
# Phone number without country code or special characters
OWNER_PHONE_NUMBER=5551234567

# ============================================================================
# FREELANCE PLATFORM APIs (For Real Gig Data)
# ============================================================================

# ----------------------------------------------------------------------------
# Upwork API (Highest Priority - Recommended)
# ----------------------------------------------------------------------------
# Get API credentials from: https://www.upwork.com/services/api/keys
# Documentation: https://developers.upwork.com/
#
# Steps to get credentials:
# 1. Log into your Upwork account
# 2. Go to Settings > API Access (or visit link above)
# 3. Create a new API key (select OAuth 2.0)
# 4. Request permission: "Read marketplace Job Postings - Public"
# 5. Copy the credentials below

UPWORK_CLIENT_ID=your_upwork_client_id_here
UPWORK_CLIENT_SECRET=your_upwork_client_secret_here
UPWORK_ACCESS_TOKEN=your_upwork_access_token_here
UPWORK_REFRESH_TOKEN=your_upwork_refresh_token_here

# ----------------------------------------------------------------------------
# Freelancer.com API (Recommended)
# ----------------------------------------------------------------------------
# Get API credentials from: https://developers.freelancer.com/
# Documentation: https://github.com/freelancer/freelancer-sdk-python
#
# Steps to get credentials:
# 1. Create a Freelancer.com account
# 2. Visit https://developers.freelancer.com/
# 3. Register your application
# 4. Get OAuth 2.0 token
# 5. Copy the token below

FREELANCER_CLIENT_ID=your_freelancer_client_id_here
FREELANCER_CLIENT_SECRET=your_freelancer_client_secret_here
FREELANCER_OAUTH_TOKEN=your_freelancer_oauth_token_here

# ----------------------------------------------------------------------------
# API Configuration (Optional)
# ----------------------------------------------------------------------------

# Rate limiting (requests per minute)
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Cache time-to-live in seconds (default: 300 = 5 minutes)
CACHE_TTL_SECONDS=300

# Enable/disable specific platforms (comma-separated list)
# Options: upwork,freelancer
# Leave empty to enable all available platforms
ENABLED_PLATFORMS=upwork,freelancer

# ============================================================================
# OPTIONAL: Notification Channels
# ============================================================================

# Email Notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
FROM_EMAIL=your_email@gmail.com

# Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord Notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL

# Custom Webhook
CUSTOM_WEBHOOK_URL=https://your-custom-webhook.com/endpoint

# ============================================================================
# OPTIONAL: Advanced Configuration
# ============================================================================

# Optional: Authentication token for advanced setups
MCP_AUTH_TOKEN=your_optional_auth_token_here

# Debug mode (set to 'true' for verbose logging)
DEBUG=false
